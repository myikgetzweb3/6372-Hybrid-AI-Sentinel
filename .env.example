# 🛡️ 6372-Hybrid-AI-Sentinel - API Credentials Template
# INSTRUCTIONS: Rename this file to .env and fill in your keys.

# 🌍 Gemini AI (Required for Deep Analysis)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_QUOTA_LIMIT=1500

# 🤖 Ollama (Local AI Settings)
OLLAMA_MODEL=tinyllama
OLLAMA_API_URL=http://localhost:11434/api/generate

# 🌐 System Settings
APP_LANGUAGE=id
SOUND_INFO_PATH=data/sounds/info.wav
SOUND_ALERT_PATH=data/sounds/alert.wav

# 📝 Log Settings
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
